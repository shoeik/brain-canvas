    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "gh-pages": "^6.1.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.8"
  }
